# Cloudflare Workers Environment Variables
# Set these via: wrangler secret put VAR_NAME --env preview

# Database (D1 or external PostgreSQL via Hyperdrive)
DATABASE_URL=postgresql://user:pass@host:5432/db

# JWT
JWT_SECRET=your-64-char-random-secret-here
ENCRYPTION_KEY=your-32-char-encryption-key

# R2 Storage (MinIO/S3 compatible)
MINIO_ENDPOINT=your-account.r2.cloudflarestorage.com
MINIO_ACCESS_KEY=your-r2-access-key
MINIO_SECRET_KEY=your-r2-secret-key
MINIO_BUCKET=adamae
MINIO_PUBLIC_URL=https://pub-yourbucket.r2.dev

# AI Service (external FastAPI on Railway/RunPod)
AI_SERVICE_URL=https://your-ai-service.railway.app
AI_SERVICE_TOKEN=your-ai-service-token

# Frontend URL
CLIENT_URL=https://afrotoon-frontend.pages.dev

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret